{
  "name": "improving-recipes",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "PORT=4000 concurrently \"tsc -p tsconfig.client.json --watch\" \"ts-node-dev --respawn --transpile-only src/server.ts\"",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.client.json",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "concurrently": "^8.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
