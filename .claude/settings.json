{
  "permissions": {
    "allow": [
      "Skill(adversarial-review)",
      "Skill(create-ac)",
      "Skill(create-story)",
      "Skill(create-technical-plan)",
      "Skill(create-unit-tests)",
      "Skill(implement-story)",
      "Write(docs/stories/**)",
      "Edit(docs/stories/**)",
      "Write(.claude/current-story)",
      "Edit(.claude/current-story)",
      "Bash(bash .claude/scripts/new-story.sh *)",
      "Bash(npm test *)"
    ],
    "deny": [
      "Write(**/state.json)",
      "Edit(**/state.json)",
      "Bash(*state.json*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/enforce-skill-order.sh"
          }
        ],
        "_comment": "Enforces a skill not being used out of order."
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-secret-reads.sh"
          }
        ],
        "_comment": "Blocks reads of secret files (.env, private keys, credentials, etc.)"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/mark-step-complete.sh"
          }
        ],
        "_comment": "Marks steps in the workflow complete."
      },
      {
        "matcher": "Bash|Edit|Write|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/audit-log.sh"
          }
        ],
        "_comment": "Logs all bash, edit, write, and skill calls."
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/audit-md-reads.sh"
          }
        ],
        "_comment": "Logs all reads of md files."
      }
    ]
  }
}
